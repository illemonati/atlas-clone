#! /bin/bash

. $(dirname $0)/find_atlas

$atlas --task simulate --fixedSeed 0 --logFile simulate.out --theta 0.001

for i in {0..4}; do
	$atlas --task theta --genomeWide --bootstraps 10 --prob 1,0.5,0.1,0.05,0.01 --bam ATLAS_simulations.bam --fixedSeed $i --extraVerbose --out boot$i --logFile boot$i.out 
done
