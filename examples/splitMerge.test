#! /bin/bash

. $(dirname $0)/find_atlas

$atlas simulate --depth 8,15,2 --numReadGroups 4 --ploidy 2,2,2 --pmd 'CT5:0.2*exp(-0.2*p)+0.02;GA3:0.3' --seqType paired --type HW --sampleSize 5 --writeVariantBED

$atlas BAMDiagnostics --bam ATLAS_simulations_ind1.bam --out ATLAS_simulations_ind1

$atlas splitMerge --bam ATLAS_simulations_ind1.bam --out ATLAS_simulations_ind1 --readGroupSettings ATLAS_simulations_ind1_diagnostics.txt

samtools index ATLAS_simulations_ind1_splitMerged.bam