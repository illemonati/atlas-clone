#! /bin/bash

root=`git rev-parse --show-toplevel`
atlas=`find $root -type f -name atlas | tail -n 1`
echo "Using $atlas"

fn="polynomial(2) empiric probit"
cov="quality position context fragmentLength mappingQuality"

# noRecal
$atlas --task simulate --fixedSeed 0 --out noRecal --logFile simulate_noRecal.out > /dev/null

printf "#%-10s %s\n" "LL" "model" > ATLAS_ll.txt

for f in $fn; do
	for c in $cov; do
		model="intercept;$c:$f"
		echo "doing model $model"
		$atlas --task recal --bam noRecal.bam --fasta noRecal.fasta --recal $model --rerecalibrate --minDeltaLL 10 --fixedSeed 0 --out recal_${c}_$f --logFile recal_${c}_$f.out > /dev/null
		printf "%.4e %s\n" $(grep "Log Likelihood" recal_${c}_$f.out | tail -n 1 | awk '{print $6}') $model >> ATLAS_ll.txt
	done
done

