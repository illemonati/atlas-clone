#! /bin/bash

. $(dirname $0)/find_atlas

simulate() {
	oname=sim_$1
	M=000000
	$atlas --task simulate --chrLength ${L1}$M,${LX}$M --ploidy 2,1 --depth $depth,10 $2 \
		--fixedSeed 0 --out $1 --logFile $1.out 2> $1.err
}

theta() {
	if [[ -n $2 ]]; then
		RG="--RGInfo eE${2}_${1}_RGInfo.json"
		oname=theta_$1_eE$2
	else
		RG=""
		oname=theta_$1
	fi
	$atlas --task theta --averageDepth $depth --depth $depths --chr chr1 \
		   --bam $1.bam $RG \
		   --fixedSeed 0 --out $oname --logFile $oname.out 2> $oname.err
}

estimate() {
	oname=eE${2}_$1
	$atlas --task estimateErrors --minDeltaLL 1e-2 \
		--chr chr2 --ploidy $2 \
		--bam $1.bam --fasta $1.fasta \
		--fixedSeed 0 --out $oname --logFile $oname.out 2> $oname.err
}

# Globals
L1=10 #Mb
LX=1  #Mb
depths="10,5,2,1,0.5,0.2,0.1,0.05"
depth=$(echo $depths | awk -F "," '{print $1}')
binned="--baseQuality categorical(12,22,27,32,37,41)"

dup="--duplicationRate 0.5"
recal="intercept[0.0];quality:polynomial[0.9,0.01]"
pmd="CT5:0.2*exp(-0.3*p)+0.01;GA3:0.2*exp(-0.3*p)+0.01"
pmd=""

# Start here
simulate "default" ""
theta "default" > /dev/null &
estimate "default" "1"
theta "default" "1" > /dev/null &
estimate "default" "2"
theta "default" "2"

simulate "dup" "$dup"
theta "dup" > /dev/null &
estimate "dup" "1"
theta "dup" "1" > /dev/null &
estimate "dup" "2"
theta "dup" "2"

simulate "recal_pmd" "--recal $recal --pmd $pmd"
theta "recal_pmd" > /dev/null &
estimate "recal_pmd" "1"
theta "recal_pmd" "1" > /dev/null &
estimate "recal_pmd" "2"
theta "recal_pmd" "2"

simulate "recal_pmd_dup" "--recal $recal --pmd $pmd $dup"
theta "recal_pmd_dup" > /dev/null &
estimate "recal_pmd_dup" "1"
theta "recal_pmd_dup" "1" > /dev/null &
estimate "recal_pmd_dup" "2"
theta "recal_pmd_dup" "2"
