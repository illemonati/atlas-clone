#! /bin/bash

. $(dirname $0)/find_atlas
. $(dirname $0)/simulate --seqType paired

echo "chr1	0	1000" > bed.txt
echo "chr1	2000	2001" >> bed.txt
echo "chr1	2100	2101" >> bed.txt
echo "chr1	2110	2111" >> bed.txt
echo "chr2	1000	2000" >> bed.txt
echo "chr3	2000	3000" >> bed.txt

$atlas --task filterBAM --bam ATLAS_simulations.bam \
	   --fixedSeed 0 --out all --logFile all.out 2> all.eout

$atlas --task filterBAM --bam ATLAS_simulations.bam --regions bed.txt \
	   --fixedSeed 0 --out bed --logFile bed.out 2> bed.eout
