#! /bin/bash

. $(dirname $0)/find_atlas

# see python ../tools/plotRecal.py "0.1 + 0.8*x + 0.2*x**2 + 0.01*x**3"
model="intercept[0.1];quality:polynomial[0.8,0.2,0.01]"
pmd="singleStrand:Exponential[30,0.1,0.1,0.05]:Exponential[40,0.2,0.3,0.07]"

# Simulate polynomial model
. $(dirname $0)/simulate --recal $model --pmd $pmd --depth 10 --ploidy 2 --numReadGroups 1 --baseFreq 1,2,3,4

for dh in haploid diploid; do
	$atlas --task recal --bam ATLAS_simulations.bam --pmd $pmd --recal $model --onlyLL --fixedSeed 0 --out onlyLL_$dh --logFile onlyLL_$dh.out --genoDist $dh

	# estimate recal model using polynomial
	$atlas --task recal --bam ATLAS_simulations.bam --pmd $pmd --recal "intercept;quality:polynomial3" --minDeltaLL 1e-2 --fixedSeed 0 --out polynomial_$dh --logFile polynomial_$dh.out --genoDist $dh
done
