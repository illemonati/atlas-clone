#! /bin/bash

. $(dirname $0)/find_atlas

# see python ../tools/plotRecal.py "0.1 + 0.8*x + 0.2*x**2 + 0.01*x**3"
model="intercept[0.1];quality:polynomial[0.8,0.2]"
pmd="singleStrand:Exponential[30,0.1,0.1,0.05]:Exponential[40,0.2,0.3,0.07]"

# Simululate polynomial model
$atlas --task simulate --recal $model --pmd $pmd --fixedSeed 0 --logFile simulate.out --depth 10 --ploidy 2 --numReadGroups 1

for dh in haploid diploid; do
	$atlas --task recal --bam ATLAS_simulations.bam --pmd $pmd --recal $model --onlyLL --fixedSeed 0 --out onlyLL_$dh --logFile onlyLL_$dh.out --genoDist $dh

	# estimate recal model using polynomial
	$atlas --task recal --bam ATLAS_simulations.bam --pmd $pmd --recal "intercept;quality:polynomial2" --minDeltaLL 1e-4 --fixedSeed 0 --out polynomial_$dh --logFile polynomial_$dh.out --genoDist $dh
done
