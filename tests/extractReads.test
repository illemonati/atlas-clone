#! /bin/bash

. $(dirname $0)/find_atlas
. $(dirname $0)/simulate --fixedSeed 777 --writeTrueGenotypes

# prepare alleles file
#special cases:
echo "Chr Pos Ref Alt" > alleles.txt
gunzip -c simulate_trueGenotypes.vcf.gz | awk '$1!~/#/{if ($5 != ".") {print $1, $2, $4, $5}}' >> alleles.txt

out="extractReads"
$atlas --task extractReads --alleles alleles.txt --bam simulate.bam \
	   --fixedSeed 111 --out $out --logFile $out.out 2> $out.eout
