#! /bin/bash

. $(dirname $0)/find_atlas

bname=$(basename $0)
name=${bname%.simulate}
out=$name/$name
M="000127"

$atlas --task simulate --vcf \
	   --chrLength 10$M,1$M --ploidy 2,1 --depth 10,2 \
	   --baseFreq 0.2,0.23,0.27,0.3 --refDiv 0.05 \
	   --fixedSeed 0 --out $out --logFile $out.out 2> $out.err > /dev/null
